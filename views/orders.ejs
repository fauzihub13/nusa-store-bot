<%- include('layout') %>
<div class="page-header">
  <h1>Pesanan</h1>
</div>

<div class="card">
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>Order ID</th>
          <th>Pembeli</th>
          <th>Produk</th>
          <th>Total</th>
          <th>Bayar Via</th>
          <th>Status</th>
          <th>Expire</th>
        </tr>
      </thead>
      <tbody>
        <% if (orders.length === 0) { %>
        <tr><td colspan="7" style="text-align:center;color:var(--text-secondary)">Belum ada pesanan</td></tr>
        <% } else { %>
        <% orders.forEach(order => { %>
        <tr>
          <td><code><%= order.orderId %></code></td>
          <td><%= order.user.firstName %><br><small style="color:var(--text-secondary)">@<%= order.user.username || '-' %></small></td>
          <td><%= order.items.map(i => i.product.name).join(', ') %></td>
          <td>Rp<%= order.totalAmount.toLocaleString('id-ID') %></td>
          <td><span class="status-badge status-paid"><%= order.paymentType || '-' %></span></td>
          <td><span class="status-badge status-<%= order.status %>"><%= order.status.toUpperCase() %></span></td>
          <td style="font-size:12px"><%= order.expiresAt.toLocaleDateString('id-ID') %></td>
        </tr>
        <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
<%- include('partials/footer') %>
