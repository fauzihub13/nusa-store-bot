<%- include('layout') %>
<div class="page-header">
  <h1>Produk</h1>
  <a href="/admin/products/add" class="btn btn-primary">+ Tambah Produk</a>
</div>

<div class="card">
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>Nama</th>
          <th>Harga</th>
          <th>Durasi</th>
          <th>Group ID</th>
          <th>Status</th>
          <th>Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% if (products.length === 0) { %>
        <tr><td colspan="6" style="text-align:center;color:var(--text-secondary)">Belum ada produk</td></tr>
        <% } else { %>
        <% products.forEach(product => { %>
        <tr>
          <td><strong><%= product.name %></strong></td>
          <td>Rp<%= product.price.toLocaleString('id-ID') %></td>
          <td><%= product.durationDays %> hari</td>
          <td><code style="font-size:11px"><%= product.groupId || '-' %></code></td>
          <td>
            <form method="POST" action="/admin/products/<%= product.id %>/toggle" style="display:inline">
              <button type="submit" class="status-badge <%= product.isActive ? 'status-delivered' : 'status-failed' %>" style="cursor:pointer;border:none">
                <%= product.isActive ? 'ON' : 'OFF' %>
              </button>
            </form>
          </td>
          <td style="white-space:nowrap">
            <a href="/admin/products/<%= product.id %>/edit" class="btn btn-ghost btn-sm">Edit</a>
            <form method="POST" action="/admin/products/<%= product.id %>/delete" style="display:inline" onsubmit="return confirm('Hapus?')">
              <button type="submit" class="btn btn-danger btn-sm">Hapus</button>
            </form>
          </td>
        </tr>
        <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
<%- include('partials/footer') %>
