<%- include('layout') %>
<div class="page-header">
  <h1>Users</h1>
</div>

<div class="card">
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>Telegram ID</th>
          <th>Username</th>
          <th>Nama</th>
          <th>Pesanan</th>
          <th>Terdaftar</th>
        </tr>
      </thead>
      <tbody>
        <% if (users.length === 0) { %>
        <tr><td colspan="5" style="text-align:center;color:var(--text-secondary)">Belum ada user</td></tr>
        <% } else { %>
        <% users.forEach(user => { %>
        <tr>
          <td><code><%= user.telegramId %></code></td>
          <td><%= user.username || '-' %></td>
          <td><%= user.firstName %> <%= user.lastName || '' %></td>
          <td><%= user._count.orders %></td>
          <td><%= user.createdAt.toLocaleDateString('id-ID') %></td>
        </tr>
        <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
<%- include('partials/footer') %>
